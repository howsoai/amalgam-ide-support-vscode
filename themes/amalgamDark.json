{
  "name": "Amalgam Dark",
  "settings": [
    {
      "name": "markup.bold",
      "scope": ["markup.bold"],
      "settings": {
        "foreground": "#E0B882",
        "fontStyle": "bold"
      }
    },
    {
      "name": "punctuation.definition.bold",
      "scope": ["punctuation.definition.bold"],
      "settings": {
        "foreground": "#C8B050",
        "fontStyle": "bold"
      }
    },
    {
      "name": "comment",
      "scope": ["comment", "comment.markup.link", "punctuation.definition.comment"],
      "settings": {
        "foreground": "#777777",
        "fontStyle": "italic"
      }
    },
    {
      "name": "invalid.deprecated",
      "scope": ["invalid.deprecated"],
      "settings": {
        "background": "#993D00",
        "foreground": "#FFB380"
      }
    },
    {
      "name": "invalid.illegal",
      "scope": ["invalid.illegal"],
      "settings": {
        "background": "#3A0000",
        "foreground": "#FF5555"
      }
    },
    {
      "name": "italic",
      "scope": ["markup.italic", "punctuation.definition.italic"],
      "settings": {
        "foreground": "#D899ED",
        "fontStyle": "italic"
      }
    },
    {
      "name": "underline",
      "scope": ["underline"],
      "settings": {
        "fontStyle": "underline"
      }
    },
    {
      "name": "@hue-1",
      "scope": [
        "constant.character.escape",
        "constant.other.color",
        "constant.other.symbol",
        "string.regexp",
        "support.type",
        "support.function"
      ],
      "settings": {
        "foreground": "#44DD88",
        "fontStyle": "bold"
      }
    },
    {
      "name": "@hue-2",
      "scope": [
        "entity.name.function",
        "entity.name.section",
        "entity.other.attribute-name.id",
        "keyword.other.special-method",
        "markup.heading.punctuation.definition.heading",
        "meta.require",
        "punctuation.definition.heading",
        "punctuation.definition.identity",
        "support.function.any-method"
      ],
      "settings": {
        "foreground": "#E040C8",
        "fontStyle": "bold"
      }
    },
    {
      "name": "@hue-3",
      "scope": [
        "keyword",
        "keyword.control",
        "markup.changed",
        "markup.italic",
        "markup.link",
        "meta.selector",
        "punctuation.definition.italic",
        "storage",
        "storage.type.annotation",
        "storage.type.primitive"
      ],
      "settings": {
        "foreground": "#5588FF",
        "fontStyle": "bold"
      }
    },
    {
      "name": "@hue-4",
      "scope": ["entity.other.inherited-class", "markup.inserted", "markup.raw", "string"],
      "settings": {
        "foreground": "#55CC55",
        "fontStyle": "bold"
      }
    },
    {
      "name": "@hue-5",
      "scope": [
        "entity.name.tag",
        "markup.deleted",
        "markup.heading",
        "meta.definition.variable",
        "string.other.link",
        "variable"
      ],
      "settings": {
        "foreground": "#E06666",
        "fontStyle": "bold"
      }
    },
    {
      "name": "@hue-5-2",
      "scope": ["punctuation.section.embedded", "variable.interpolation"],
      "settings": {
        "foreground": "#33BBBB"
      }
    },
    {
      "name": "@hue-6-2",
      "scope": [
        "entity.name.type.class",
        "entity.name.type",
        "meta.class",
        "punctuation.definition.bold",
        "string.regexp.source.ruby.embedded",
        "support.class"
      ],
      "settings": {
        "foreground": "#D07858",
        "fontStyle": "bold"
      }
    },
    {
      "name": "@hue-6",
      "scope": [
        "constant",
        "constant.numeric",
        "constant.variable",
        "entity.other.attribute-name",
        "keyword.other.unit",
        "markup.bold",
        "markup.quote",
        "meta.link"
      ],
      "settings": {
        "foreground": "#6699FF",
        "fontStyle": "bold"
      }
    },
    {
      "name": "@mono-1",
      "scope": [
        "meta.class.body",
        "meta.method",
        "meta.tag",
        "none",
        "punctuation.definition.array",
        "punctuation.definition.function-parameters",
        "punctuation.definition.method-parameters",
        "punctuation.definition.parameters",
        "punctuation.definition.separator",
        "punctuation.section.class",
        "punctuation.section.inner-class",
        "punctuation.section.method",
        "storage.modifier.import",
        "storage.modifier.package"
      ],
      "settings": {
        "foreground": "#ABB2BE"
      }
    },
    {
      "name": "@mono-2",
      "scope": ["variable.parameter"],
      "settings": {
        "foreground": "#888888"
      }
    },
    {
      "name": "@mono-3",
      "scope": ["keyword.codetag.notation"],
      "settings": {
        "foreground": "#6699FF",
        "fontStyle": "italic"
      }
    }
  ]
}
