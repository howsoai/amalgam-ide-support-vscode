;print json of all help documentation for every opcode
(print
	(format
		(sort
			(lambda (> (get (current_value) "opcode") (get (current_value 1) "opcode")))
			(map
				(lambda (set (help (current_value)) "opcode" (current_value)))
				(help "opcodes")
			)
		)
		"code"
		"json"
		.null
		{"sort_keys" .true}
	)
)